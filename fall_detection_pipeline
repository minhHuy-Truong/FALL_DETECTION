	}
	subgraph cluster_output {
		color="#80868B" label="Giai đoạn Cuối: Tổng hợp & Cảnh báo" penwidth=2 style=dashed
		Ensemble [label="Ensemble: Weighted Voting
(Tính điểm theo trọng số)" color="#D93025" fillcolor="#FCE8E6" shape=ellipse]
		Alert [label="CẢNH BÁO TÉ NGÃ!
