	MP -> M_C [label=" Đồ thị xương đơn"]
	MP -> M_D [label=" Chuỗi Pose 16 Frames"]
	M_A -> Ensemble [label=" Vote (mAP)"]
	M_B -> Ensemble [label=" Vote (Acc)"]
	M_C -> Ensemble [label=" Vote (Acc)"]
	M_D -> Ensemble [label=" Vote (Acc)"]
	Ensemble -> Alert [label=" Vượt ngưỡng tin cậy"]
	Ensemble -> Normal [label=" Dưới ngưỡng"]
